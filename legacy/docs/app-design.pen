                      "layout": "vertical",
                      "gap": 12,
                      "padding": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "Gu0bg",
                          "name": "ctrTitle",
                          "fill": "#F5A623",
                          "content": "Steel-Manned Opposition",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 14,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "p9vWf",
                          "name": "ctrText",
                          "fill": "#A1A1AA",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The analysis overweights the historical trust destruction and underweights the power asymmetry. The US has demonstrated it can strike with impunity. Iran's 'grim trigger' may be rhetoric — they negotiated the JCPOA under severe sanctions pressure before. A credible 'take it or leave it' offer backed by continued military pressure could force settlement within 6 months.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "luyOk",
                          "name": "ctrRebutLabel",
                          "fill": "#71717A",
                          "content": "Rebuttal:",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "wKxPk",
                          "name": "ctrRebut",
                          "fill": "#71717A",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "This argument fails because the 2015 context was fundamentally different — Iran had moderates in power who could sell the deal domestically. The adverse selection pattern has since eliminated moderates.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
