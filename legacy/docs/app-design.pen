                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "uC3f6",
                  "name": "sensText",
                  "fill": "#A1A1AA",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Prolonged Attrition collapses — regime accepts destruction over capitulation\n\nRegional Escalation probability jumps to 50%+\n\nWar of attrition with no rational stopping point becomes the primary scenario\n\nAll equilibrium analysis assuming rational cost-minimization breaks down",
                  "lineHeight": 1.3,
                  "fontFamily": "Space Grotesk",
                  "fontSize": 10,
                  "fontWeight": "normal"
                },
