                  "name": "sensHead",
                  "fill": "#EF4444",
                  "content": "SENSITIVITY ANALYSIS — IF WRONG",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 9,
                  "fontWeight": "700",
                  "letterSpacing": 1
                },
                {
                  "type": "text",
                  "id": "V5gx8",
                  "name": "sensImpact",
                  "fill": "#FAFAFA",
                  "content": "Impact: Flips the central prediction",
                  "fontFamily": "Space Grotesk",
