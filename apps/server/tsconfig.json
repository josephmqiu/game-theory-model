{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "lib": ["ES2023", "esnext.disposable"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@effect/platform-node"],
        "diagnosticSeverity": {
          "importFromBarrel": "error",
          "anyUnknownInErrorContext": "warning",
          "instanceOfSchema": "warning",
          "deterministicKeys": "warning",
          "preferSchemaOverJson": "off",
          "globalErrorInEffectFailure": "off"
        }
      }
    ]
  },
  "include": [
    "src",
    "tsdown.config.ts",
    "scripts",
    "integration",
    "../../scripts/lib"
  ],
  "exclude": [
    "src/wsServer.test.ts",
    "src/main.test.ts",
    "integration/orchestrationEngine.integration.test.ts",
    "integration/OrchestrationEngineHarness.integration.ts"
  ]
}
